{
  "Name": "customer_churn_scores",
  "TableType": "EXTERNAL_TABLE",
  "Parameters": {
    "classification": "csv",
    "skip.header.line.count": "1"
  },
  "StorageDescriptor": {
    "Columns": [
      { "Name": "customerid", "Type": "string" },
      { "Name": "churn_probability", "Type": "double" },
      { "Name": "predicted_churn", "Type": "int" },
      { "Name": "risk_level", "Type": "string" },
      { "Name": "actual_churn", "Type": "int" },
      { "Name": "contract", "Type": "string" },
      { "Name": "tenure", "Type": "int" },
      { "Name": "monthlycharges", "Type": "double" },
      { "Name": "totalcharges", "Type": "double" },
      { "Name": "paymentmethod", "Type": "string" },
      { "Name": "internetservice", "Type": "string" }
    ],
    "Location": "s3://YOUR_BUCKET_NAME/churn-project/scores/",
    "InputFormat": "org.apache.hadoop.mapred.TextInputFormat",
    "OutputFormat": "org.apache.hadoop.hive.ql.io.HiveIgnoreKeyTextOutputFormat",
    "SerdeInfo": {
      "SerializationLibrary": "org.apache.hadoop.hive.serde2.OpenCSVSerde",
      "Parameters": {
        "separatorChar": ",",
        "quoteChar": "\"",
        "escapeChar": "\\"
      }
    }
  }
}
